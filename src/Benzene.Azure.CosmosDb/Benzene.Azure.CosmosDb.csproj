<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Benzene.Azure.CosmosDb</AssemblyName>
    <RootNamespace>Benzene.Azure.CosmosDb</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Azure.Cosmos" Version="3.62.0" />
    <!-- Required explicitly by Microsoft.Azure.Cosmos's build check; same pin as Benzene.NewtonsoftJson -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Benzene.Core.MessageHandlers\Benzene.Core.MessageHandlers.csproj" />
    <ProjectReference Include="..\Benzene.Core\Benzene.Core.csproj" />
    <ProjectReference Include="..\Benzene.SelfHost\Benzene.SelfHost.csproj" />
  </ItemGroup>

</Project>
