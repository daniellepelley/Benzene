<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Benzene.Mesh.GoogleCloud.Storage</AssemblyName>
    <RootNamespace>Benzene.Mesh.GoogleCloud.Storage</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>Google Cloud Storage artifact store for the Benzene Mesh aggregator: an IMeshArtifactStore that persists the generated catalog (manifest/services/topics/topology) and the discovered registry.json as GCS objects, the Google Cloud analogue of Benzene.Mesh.Aws.S3 / Benzene.Mesh.Azure.Blob. Adds AddMeshAggregatorWithGcs.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Cloud.Storage.V1" Version="4.15.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Benzene.Abstractions\Benzene.Abstractions.csproj" />
    <ProjectReference Include="..\Benzene.Mesh.Aggregator\Benzene.Mesh.Aggregator.csproj" />
  </ItemGroup>

</Project>
