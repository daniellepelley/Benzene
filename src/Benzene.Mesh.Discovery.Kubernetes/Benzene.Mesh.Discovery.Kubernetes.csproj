<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Benzene.Mesh.Discovery.Kubernetes</AssemblyName>
    <RootNamespace>Benzene.Mesh.Discovery.Kubernetes</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>Kubernetes self-discovery for the Benzene Mesh: lists the Services in a cluster (filtered by label, e.g. benzene) and emits HTTP mesh registry entries pointing at their in-cluster DNS, so the aggregator discovers services instead of being hand-fed a mesh.json. Reuses the default HTTP interrogation source.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="KubernetesClient" Version="15.0.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Benzene.Abstractions\Benzene.Abstractions.csproj" />
    <ProjectReference Include="..\Benzene.Mesh.Contracts\Benzene.Mesh.Contracts.csproj" />
  </ItemGroup>

</Project>
