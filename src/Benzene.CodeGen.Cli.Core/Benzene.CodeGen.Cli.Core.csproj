<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Benzene.CodeGen.Cli.Core</AssemblyName>
    <RootNamespace>Benzene.CodeGen.Cli.Core</RootNamespace>
    <!--
      Not part of the 1.0 NuGet release. This is the internal command layer of the `benzene` CLI
      tool (Benzene.CodeGen.Cli, PackAsTool) and is not a consumable library: it is referenced only
      by that tool, has no package metadata, bundles a project-specific reference assembly
      (Resources/platform-tenant-core-func.dll), and pulls in the still-project-specific
      Benzene.CodeGen.ApiGateway generator. The tool bundles this assembly regardless of IsPackable,
      so the readme / api-gateway CLI outputs still work; we just don't publish it as its own
      package. (This also avoids a dangling package dependency now that Benzene.CodeGen.Markdown is
      unpacked.)
    -->
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="Resources\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AWSSDK.SecurityToken" Version="3.7.300.33" />
    <PackageReference Include="System.Reflection.MetadataLoadContext" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Benzene.Clients.Aws\Benzene.Clients.Aws.csproj" />
    <ProjectReference Include="..\Benzene.CloudService.Probe\Benzene.CloudService.Probe.csproj" />
    <ProjectReference Include="..\Benzene.CodeGen.ApiGateway\Benzene.CodeGen.ApiGateway.csproj" />
    <ProjectReference Include="..\Benzene.CodeGen.Client\Benzene.CodeGen.Client.csproj" />
    <ProjectReference Include="..\Benzene.CodeGen.LambdaTestTool\Benzene.CodeGen.LambdaTestTool.csproj" />
    <ProjectReference Include="..\Benzene.CodeGen.Markdown\Benzene.CodeGen.Markdown.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Resources\platform-tenant-core-func.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
