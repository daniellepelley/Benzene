<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Benzene.Mesh.Azure.Blob</AssemblyName>
    <RootNamespace>Benzene.Mesh.Azure.Blob</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>Azure Blob Storage artifact store for the Benzene Mesh aggregator: an IMeshArtifactStore that persists the generated catalog (manifest/services/topics/topology) and the discovered registry.json as blobs, the Azure analogue of Benzene.Mesh.Aws.S3. Adds AddMeshAggregatorWithBlob.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Storage.Blobs" Version="12.22.2" />
    <PackageReference Include="Azure.Identity" Version="1.13.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Benzene.Abstractions\Benzene.Abstractions.csproj" />
    <ProjectReference Include="..\Benzene.Mesh.Aggregator\Benzene.Mesh.Aggregator.csproj" />
  </ItemGroup>

</Project>
