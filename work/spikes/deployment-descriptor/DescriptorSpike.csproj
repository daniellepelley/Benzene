<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Throwaway spike for the deployment-descriptor investigation (see ../../deployment-descriptor-design.md).
    Deliberately NOT part of Benzene.sln / Benzene.Examples.sln — it references an example service project
    only to prove the build-time, non-running extraction works against a real service.
    Run with: dotnet run, from this folder.
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <AssemblyName>DescriptorSpike</AssemblyName>
    <RootNamespace>DescriptorSpike</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- The real service under inspection, with its whole dependency closure. -->
    <ProjectReference Include="..\..\..\examples\AwsMesh\Payments\Benzene.Examples.AwsMesh.Payments.csproj" />
    <!-- Build-time construction seam + in-memory invoke, exactly as the runtime host does it. -->
    <ProjectReference Include="..\..\..\src\Benzene.Testing\Benzene.Testing.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Tools\Benzene.Tools.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Aws.Lambda.Core.TestHelpers\Benzene.Aws.Lambda.Core.TestHelpers.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Core.MessageHandlers.TestHelpers\Benzene.Core.MessageHandlers.TestHelpers.csproj" />
    <!-- The mesh ServiceDescriptor factory (build directly from handler types, no host). -->
    <ProjectReference Include="..\..\..\src\Benzene.Mesh.Wire\Benzene.Mesh.Wire.csproj" />
  </ItemGroup>

</Project>
