<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <AssemblyName>Benzene.Examples.AwsMesh.Notifications</AssemblyName>
    <RootNamespace>Benzene.Examples.AwsMesh.Notifications</RootNamespace>
    <!-- .NET 10 has no managed Lambda runtime; deploy self-contained on provided.al2023. -->
    <AWSProjectType>Lambda</AWSProjectType>
    <GenerateRuntimeConfigurationFiles>true</GenerateRuntimeConfigurationFiles>
    <!-- provided.al2023 ships no libicu; run globalization-invariant so the apphost starts. -->
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Amazon.Lambda.RuntimeSupport" Version="1.10.0" />
    <PackageReference Include="Amazon.Lambda.Core" Version="2.2.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Ship the ADOT collector config into the Lambda zip (published to /var/task/collector.yaml),
         selected via OPENTELEMETRY_COLLECTOR_CONFIG_URI so the collector forwards traces to X-Ray. -->
    <Content Include="..\collector.yaml" Link="collector.yaml" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Shared\Benzene.Examples.AwsMesh.Shared.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Aws.Lambda.Core\Benzene.Aws.Lambda.Core.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Aws.Lambda.ApiGateway\Benzene.Aws.Lambda.ApiGateway.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.CloudService\Benzene.CloudService.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Schema.OpenApi\Benzene.Schema.OpenApi.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.HealthChecks\Benzene.HealthChecks.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Spec.Ui\Benzene.Spec.Ui.csproj" />
    <ProjectReference Include="..\..\..\src\Benzene.Microsoft.Dependencies\Benzene.Microsoft.Dependencies.csproj" />
  </ItemGroup>

</Project>
