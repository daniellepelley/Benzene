<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- Benzene's transport-agnostic in-memory host (BenzeneMessage), used by the tests to route a
         topic through your handlers without the real transport. Version="*-*" floats to the latest
         published prerelease, matching the main project. -->
    <PackageReference Include="Benzene.Core.MessageHandlers" Version="*-*" />
    <PackageReference Include="Benzene.Microsoft.Dependencies" Version="*-*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BenzeneStarter.csproj" />
  </ItemGroup>

</Project>
