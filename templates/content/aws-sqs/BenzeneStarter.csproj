<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Benzene's packages are prerelease (-alpha) until 1.0 - Version="*-*" floats to the latest
         published version (including prereleases) on every restore, matching what the prerelease flag means
         when you run `dotnet add package` yourself. -->
    <PackageReference Include="Benzene.Aws.Lambda.Core" Version="*-*" />
    <PackageReference Include="Benzene.Aws.Lambda.Sqs" Version="*-*" />
    <!-- Not pulled in transitively by Benzene.Aws.Lambda.Sqs (SQS doesn't need HTTP routing) -
         referenced explicitly because the starter handler's [HttpEndpoint] attribute needs it
         (harmless/unused on this transport - see HelloWorldMessageHandler.cs). -->
    <PackageReference Include="Benzene.Http" Version="*-*" />
    <!-- Only Benzene's own GetConfiguration() needs a concrete Microsoft.Extensions.Configuration
         implementation - only its abstractions come in transitively via Benzene. -->
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.FileExtensions" Version="10.0.9" />
  </ItemGroup>

</Project>
