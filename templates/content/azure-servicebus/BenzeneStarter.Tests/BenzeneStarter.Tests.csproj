<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- Benzene's test host: BenzeneTestHost.Create<StartUp>() boots the app exactly as the real host
         does (ConfigureServices + Configure), with WithServices/WithConfiguration override seams. The
         Azure Functions helpers add BuildAzureFunctionApp() and AsAzureServiceBusMessage(). Version
         "*-*" floats to the latest published prerelease, matching the main project. -->
    <PackageReference Include="Benzene.Testing" Version="*-*" />
    <PackageReference Include="Benzene.Azure.Function.Core.TestHelpers" Version="*-*" />
    <PackageReference Include="Benzene.Azure.Function.ServiceBus.TestHelpers" Version="*-*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BenzeneStarter.csproj" />
  </ItemGroup>

</Project>
