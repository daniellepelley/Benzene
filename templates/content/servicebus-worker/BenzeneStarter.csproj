<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- The optional unit-test project is generated as a sibling in the BenzeneStarter.Tests subfolder.
       Keep its sources out of THIS project's compilation (it's a separate project). Matches nothing -
       and is harmless - if you generated without the test project. -->
  <ItemGroup>
    <Compile Remove="BenzeneStarter.Tests\**" />
    <Content Remove="BenzeneStarter.Tests\**" />
    <None Remove="BenzeneStarter.Tests\**" />
  </ItemGroup>

  <ItemGroup>
    <!-- Benzene's packages are prerelease (-alpha) until 1.0 - Version="*-*" floats to the latest
         published version (including prereleases) on every restore. Azure.Messaging.ServiceBus comes in
         transitively from Benzene.Azure.ServiceBus. -->
    <PackageReference Include="Benzene.Azure.ServiceBus" Version="*-*" />
    <PackageReference Include="Benzene.SelfHost" Version="*-*" />
    <!-- Adds AddDiagnostics() (Activity span per middleware) and UseBenzeneEnrichment() (log/trace
         enrichment). See docs/monitoring.md and docs/diagnosing-failures.md. -->
    <PackageReference Include="Benzene.Diagnostics" Version="*-*" />
    <PackageReference Include="Benzene.HostedService" Version="*-*" />
    <!-- Benzene.HostedService/Benzene.SelfHost only bring in the .Abstractions packages transitively -
         the concrete Host.CreateDefaultBuilder/ConfigurationBuilder implementations used in
         Program.cs/StartUp.cs need these referenced directly, the same way `dotnet new worker` does. -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.9" />
  </ItemGroup>

</Project>
