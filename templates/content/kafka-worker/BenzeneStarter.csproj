<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Benzene's packages are prerelease (-alpha) until 1.0 - Version="*-*" floats to the latest
         published version (including prereleases) on every restore, matching what the prerelease flag means
         when you run `dotnet add package` yourself. Confluent.Kafka comes in transitively
         from Benzene.Kafka.Core. -->
    <PackageReference Include="Benzene.Kafka.Core" Version="*-*" />
    <PackageReference Include="Benzene.HostedService" Version="*-*" />
    <PackageReference Include="Benzene.SelfHost" Version="*-*" />
    <!-- Benzene.HostedService/Benzene.SelfHost only bring in the .Abstractions packages
         transitively - the concrete Host.CreateDefaultBuilder/ConfigurationBuilder
         implementations used in Program.cs/StartUp.cs need these referenced directly, the same
         way `dotnet new worker` itself references Microsoft.Extensions.Hosting. -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.9" />
  </ItemGroup>

</Project>
