<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- The optional unit-test project is generated as a sibling in the BenzeneStarter.Tests subfolder.
       Keep its sources out of THIS project's compilation (it's a separate project). Matches nothing -
       and is harmless - if you generated without the test project. -->
  <ItemGroup>
    <Compile Remove="BenzeneStarter.Tests\**" />
    <Content Remove="BenzeneStarter.Tests\**" />
    <None Remove="BenzeneStarter.Tests\**" />
  </ItemGroup>

  <ItemGroup>
    <!-- Benzene's packages are prerelease (-alpha) until 1.0 - Version="*-*" floats to the latest
         published version (including prereleases) on every restore, matching what the prerelease flag means
         when you run `dotnet add package` yourself. See README.md in this project for details. -->
    <PackageReference Include="Benzene.AspNet.Core" Version="*-*" />
    <!-- Adds AddDiagnostics() (Activity span per middleware) and UseBenzeneEnrichment() (log/trace
         enrichment). See docs/monitoring.md and docs/diagnosing-failures.md. -->
    <PackageReference Include="Benzene.Diagnostics" Version="*-*" />
  </ItemGroup>

</Project>
