{
  "description": "Benzene<->gRPC status mapping (wire-contracts.md section 4.2). Forward: server mapping a result status to a gRPC StatusCode. Reverse: client mapping a gRPC StatusCode back to a result status when no benzene-status trailer is present (a trailer, when present, wins verbatim - covered by implementation tests, not these tables).",
  "forward": [
    { "from": "ok", "to": "OK" },
    { "from": "ignored", "to": "OK" },
    { "from": "created", "to": "OK" },
    { "from": "accepted", "to": "OK" },
    { "from": "updated", "to": "OK" },
    { "from": "deleted", "to": "OK" },
    { "from": "bad-request", "to": "InvalidArgument" },
    { "from": "validation-error", "to": "InvalidArgument" },
    { "from": "unauthorized", "to": "Unauthenticated" },
    { "from": "forbidden", "to": "PermissionDenied" },
    { "from": "not-found", "to": "NotFound" },
    { "from": "conflict", "to": "AlreadyExists" },
    { "from": "not-implemented", "to": "Unimplemented" },
    { "from": "service-unavailable", "to": "Unavailable" },
    { "from": "too-many-requests", "to": "ResourceExhausted" },
    { "from": "timeout", "to": "DeadlineExceeded" },
    { "from": "unexpected-error", "to": "Internal" },
    { "from": "<unknown>", "to": "Internal" }
  ],
  "reverse": [
    { "from": "OK", "to": "ok" },
    { "from": "InvalidArgument", "to": "bad-request" },
    { "from": "Unauthenticated", "to": "unauthorized" },
    { "from": "PermissionDenied", "to": "forbidden" },
    { "from": "NotFound", "to": "not-found" },
    { "from": "AlreadyExists", "to": "conflict" },
    { "from": "Unimplemented", "to": "not-implemented" },
    { "from": "Unavailable", "to": "service-unavailable" },
    { "from": "ResourceExhausted", "to": "too-many-requests" },
    { "from": "DeadlineExceeded", "to": "timeout" },
    { "from": "Cancelled", "to": "service-unavailable" },
    { "from": "DataLoss", "to": "unexpected-error" },
    { "from": "Internal", "to": "unexpected-error" }
  ]
}
